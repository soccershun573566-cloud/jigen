# ジゲン 環境変数テンプレート(技術構築計画§1.3)
# このファイルをコピーして .env.local を作成し値を埋める

# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ---------- OpenAI ----------
OPENAI_API_KEY=
OPENAI_MONTHLY_BUDGET_JPY=30000

# ---------- Stripe ----------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=

# ---------- Resend (メール) ----------
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@jigen.app

# ---------- Web Push (VAPID) ----------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@jigen.app

# ---------- Cron ----------
CRON_SECRET=

# ---------- Sentry ----------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ---------- PostHog ----------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
POSTHOG_API_KEY=

# ---------- App ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- Admin BasicAuth ----------
ADMIN_BASIC_AUTH_USER=
ADMIN_BASIC_AUTH_PASS=
